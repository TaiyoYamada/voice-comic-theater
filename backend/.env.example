# ===== バックエンド設定（コピーして .env を作成）=====
# Colab では os.environ に設定するため、このファイルは主にローカル開発用。
#
# アプリの「既定」は本番バックエンド（whisper / qwen）です。
# GPU の無いローカル開発では、下のように dummy にしておくと軽く動きます
# （依存が無ければ自動で dummy にフォールバックもします）。

# 文字起こしバックエンド: whisper（既定） | dummy
TRANSCRIBE_BACKEND=dummy
# whisper のモデル名（whisper のとき）
WHISPER_MODEL=base

# TTS（音声生成）バックエンド: qwen（既定・声クローン） | dummy
TTS_BACKEND=dummy
# Qwen3-TTS のモデル（qwen のとき）
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# 生成する言語
TTS_LANGUAGE=Japanese

# 出力・一時ディレクトリ
OUTPUT_DIR=output
TMP_DIR=tmp

# CORS 許可オリジン（カンマ区切り）。* で全許可（開発用）。
CORS_ORIGINS=*

# ffmpeg の実行ファイル名（PATH 上にあれば ffmpeg のままでよい）
FFMPEG_BIN=ffmpeg
