# ===== Colab 起動用の設定（直書き禁止。Colab のシークレット or os.environ で渡す）=====

# ngrok の認証トークン（https://dashboard.ngrok.com/get-started/your-authtoken）
NGROK_AUTHTOKEN=

# GAS の Web アプリ URL（サーバーレジストリ）
GAS_URL=https://script.google.com/macros/s/XXXX/exec

# このColabの識別情報（台ごとに変える）
SERVER_ID=colab-1
SERVER_COLOR=red
SERVER_LABEL=赤サーバー

# 1台で受け入れる人数（1〜2人を想定）
CAPACITY=2

# 任意
PORT=8000
HEARTBEAT_SEC=30
